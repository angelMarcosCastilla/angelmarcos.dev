---
import Subtitle from './Subtitle.astro'
import Html from './icon/Html.astro'
import Css from './icon/Css.astro'
import Js from './icon/Js.astro'
import React from './icon/React.astro'
import MaterialUi from './icon/MaterialUi.astro'
import Reactroute from './icon/Reactroute.astro'
import Next from './icon/Next.astro'
import AstroIcon from './icon/AstroIcon.astro'
import Svelte from './icon/Svelte.astro'
import NodeIcon from './icon/NodeIcon.astro'
import Mysql from './icon/Mysql.astro'
import Tailwind from './icon/Tailwind.astro'
import Redux from './icon/Redux.astro'
import Php from './icon/Php.astro'
import { SKILLS } from '../data/skills'

const skillsIcons: Record<string, any> = {
  html: Html,
  css: Css,
  js: Js,
  react: React,
  materialui: MaterialUi,
  reactroute: Reactroute,
  next: Next,
  astro: AstroIcon,
  svelte: Svelte,
  node: NodeIcon,
  mysql: Mysql,
  tailwind: Tailwind,
  redux: Redux,
  php: Php
}
---

<section class='py-12'>
  <Subtitle title='Habilidades ' />
  <div class='flex flex-wrap gap-3 justify-center mt-12'>
    {
      SKILLS.map((skill) => {
        const IconComponent = skillsIcons[skill.id]
        return (
          <div class='skill-chip'>
            <IconComponent />
            <span class='skill-chip-label'>{skill.name}</span>
          </div>
        )
      })
    }
  </div>
</section>

<style>
  .skill-chip {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border-radius: 9999px;
    backdrop-filter: blur(10px);
    background: hsla(var(--secondary) / 0.5);
    border: 1px solid hsla(var(--secondary) / 0.3);
    transition: all 0.3s ease;
    white-space: nowrap;
  }

  .skill-chip:hover {
    background: hsla(var(--secondary) / 0.7);
    border-color: hsla(var(--secondary) / 0.6);
    transform: translateY(-2px);
  }

  .skill-chip :global(svg) {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .skill-chip-label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
  }
</style>
